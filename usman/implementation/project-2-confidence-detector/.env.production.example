# ─────────────────────────────────────────────────────────────────────
# Production environment template for confidence-detector backend.
#
#   1. Copy to `.env` on the deploy host: `cp .env.production.example .env`
#   2. Fill in real values (the placeholders below will REFUSE to start
#      the app — `ENV=production` plus a missing JWT_SECRET raises a
#      RuntimeError at startup, by design).
#   3. NEVER commit the filled-in `.env`. The `.env` file is already in
#      `.dockerignore` + `.gitignore`.
#
# This file documents every env knob the backend reads. Sane production
# defaults are noted next to each variable.
# ─────────────────────────────────────────────────────────────────────


# === Required: refuse-to-start unless set in production mode ==========

# Tells the app to enforce production safety checks (no JWT fallback,
# no signed-URL fallback, no DB password default). Anything other
# than 'production' (e.g. 'dev') re-enables the unsafe fallbacks.
ENV=production

# Pin the docker-compose project name so volumes / networks /
# containers get a predictable prefix regardless of which directory
# runs `docker compose`. Without this, compose derives the project
# name from the directory basename — and since the deployable
# subfolder is `project-2-confidence-detector/`, every volume
# would be named `project-2-confidence-detector_uploads-data`
# instead of the cleaner `confidence-detector_uploads-data`.
# Read by docker-compose at parse time, NOT by the backend app.
COMPOSE_PROJECT_NAME=confidence-detector

# Sign JWT auth tokens. Generate with:
#     python -c "import secrets; print(secrets.token_urlsafe(64))"
# A random string >= 32 chars. Rotate by issuing a new one and
# accepting both for an overlap window (current code accepts only one).
JWT_SECRET=__GENERATE_A_64_CHAR_RANDOM_STRING__

# Sign per-user playback / download URLs. Same generation pattern as
# above. Distinct from JWT_SECRET so a leaked playback URL doesn't
# compromise the auth secret.
MEDIA_URL_SECRET=__GENERATE_A_DIFFERENT_64_CHAR_STRING__


# === Database ========================================================
# Keep comments on their own lines — naive parsers (bash `cut -d=`)
# will otherwise pick up the inline `#` text as part of the value.
# Compose itself strips inline comments correctly, but anything that
# parses .env in shell will not.

# DB_HOST: service name in docker-compose, or your VPS IP if external Postgres
DB_HOST=postgres
DB_PORT=5432
DB_NAME=confidence_detector_app
# DB_USER: NOT the default 'postgres' superuser
DB_USER=cd_app
DB_PASSWORD=__SET_A_REAL_PASSWORD__

# Connection pool sizing. Defaults (50 + 100) suit ~100 concurrent
# users. Match your Postgres `max_connections` to be larger than
# (UVICORN_WORKERS × (DB_POOL_SIZE + DB_POOL_MAX_OVERFLOW)).
DB_POOL_SIZE=50
DB_POOL_MAX_OVERFLOW=100


# === Process model ===================================================

# One worker per CPU core. A 4-core box → 4 workers. Each worker
# loads its own Whisper + MediaPipe models (~250 MB RSS each), so
# verify against your RAM budget too.
UVICORN_WORKERS=4


# === Concurrency caps ================================================

# Max simultaneous live WebSocket practice sessions. Each session
# costs ~10 MB RAM (MediaPipe models are NOT loaded for live —
# browser sends landmarks). 30 is comfortable on a 4-core/8GB box.
MAX_LIVE_SESSIONS=30

# Max simultaneous upload-analysis pipelines. Higher won't help on
# CPU because Whisper saturates 4 cores per call — keep at 2.
MAX_CONCURRENT_UPLOADS=2

# Whisper semaphore (asyncio). A single Whisper transcribe()
# already uses ctranslate2's internal `num_workers=4`, so 3
# concurrent calls on a 4-core box just contend for CPU. Keep at 3
# unless you've moved to GPU.
MAX_CONCURRENT_WHISPER=3


# === Whisper model selection =========================================

# Default `distil-small.en` is the best accuracy/speed tradeoff on
# CPU. Switch to `base.en` for ~2× speedup with negligible accuracy
# regression on typical presentation speech. `tiny.en` is ~3-4×
# faster but loses 1-2 fillers/min on quiet/hesitant speakers.
# Switch to `small.en` + WHISPER_DEVICE=cuda on a GPU box for the
# best results.
WHISPER_MODEL=distil-small.en
# WHISPER_DEVICE=auto       # auto | cpu | cuda
# WHISPER_COMPUTE=int8      # CPU default; float16 on GPU


# === Storage =========================================================

# Persistent path for user uploads. In docker-compose this is the
# named volume `uploads-data` mounted at /data/uploads. Outside
# Docker, set to a real disk path with regular backups.
UPLOAD_DIR=/data/uploads


# === Optional integrations ===========================================

# Gemini coaching. When unset the app silently falls back to
# rule-based coaching tips. Get a key from
# https://aistudio.google.com/. ROTATE if previously committed.
# GEMINI_API_KEY=

# Sentry error tracking. The handler ships errors as structured
# JSON logs by default — Sentry adds breadcrumbs + alerting.
# Add `sentry-sdk[fastapi]` to requirements.txt and a 3-line init
# in main.py if you want this; not wired by default.
# SENTRY_DSN=


# === Rate-limiting / silencing knobs (rarely tuned) ==================

# slowapi global default. Per-endpoint decorators already cap the
# hot routes; this only catches anything not explicitly limited.
# RATE_LIMIT_DEFAULT=120/minute

# Silent-input volumedetect threshold. Below this dBFS the audio
# pre-pass rejects the upload as "no speech detected" without
# burning CPU on Whisper.
# SILENT_INPUT_THRESHOLD_DB=-50


# === Notes for the operator ==========================================
# - HTTPS is required for browser microphone/camera permission.
#   Front this app with nginx, Caddy, or Cloudflare Tunnel.
# - Run `alembic upgrade head` from inside the backend container
#   (or before container start) on every deploy to pick up new
#   schema changes.
# - Add a daily cron on the host:
#     find /var/lib/docker/volumes/<project>_uploads-data/_data \
#       -mtime +30 -delete
#   to purge upload files older than 30 days.
