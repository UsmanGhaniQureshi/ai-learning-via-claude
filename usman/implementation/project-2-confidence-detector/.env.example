# Confidence Detector — Environment Variables
# Copy this file to backend/.env and fill in real values.
# backend/.env is gitignored; this example is the committed template.

# ── Server ──────────────────────────────────────────────────────
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── ML models ───────────────────────────────────────────────────
WHISPER_MODEL=distil-small.en
WHISPER_DEVICE=auto
# HF_TOKEN only needed if you hit download rate limits on huggingface.
# HF_TOKEN=hf_your_token_here

# Workarounds for Windows + bundled native libs
KMP_DUPLICATE_LIB_OK=TRUE
HF_HUB_DISABLE_SYMLINKS_WARNING=1

# ── Postgres (Phase 2) ──────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=confidence_detector_app
DB_USER=postgres
DB_PASSWORD=postgres
