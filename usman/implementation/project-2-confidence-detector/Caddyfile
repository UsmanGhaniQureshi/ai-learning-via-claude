# ─────────────────────────────────────────────────────────────────────
# Caddy reverse-proxy + auto-HTTPS for the confidence-detector app.
#
# Pinned to confidence-detector.logicsbay.com on the deployment
# branch. To redeploy somewhere else, change the bare-domain line
# below (around line 35) and add a matching A record at the
# registrar.
#
# `docker compose up -d` starts Caddy, which automatically requests
# + renews Let's Encrypt certificates for the domain set below.
# First start can take 30-60 seconds while LE validates and issues
# the cert.
#
# Architecture (two-hop reverse proxy):
#
#   Browser  ─https─►  Caddy (this file, 443)
#                       │
#                       │ http (compose network)
#                       ▼
#                     frontend (nginx, port 80)
#                       │
#                       │ http (compose network)
#                       ▼
#                     backend (uvicorn, port 8000)
#
# The frontend container's own nginx (frontend/nginx.conf) routes
# /api/* and /ws/* to the backend, so Caddy doesn't need to know
# about the API layout — it just forwards everything to the
# frontend container.
# ─────────────────────────────────────────────────────────────────────

# Production domain for the confidence-detector deployment. Set
# the matching A record at the registrar for this exact subdomain
# pointing at the Contabo VPS IPv4 (and AAAA for IPv6 if available).
confidence-detector.logicsbay.com {
    # Forward ALL traffic (HTML, static assets, /api, /ws, /health)
    # to the frontend container. Caddy auto-detects WebSocket
    # upgrades and tunnels them through the same proxy without
    # explicit configuration.
    reverse_proxy frontend:80

    # Larger upload limit for video files. The default is 1 MB;
    # raise to 500 MB so users can submit longer recordings.
    request_body {
        max_size 500MB
    }

    # Sensible production defaults.
    encode zstd gzip

    # Security headers. Browsers won't grant mic/camera permission
    # over HTTP at all, so HSTS is just belt-and-braces.
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        # Permissions-Policy intentionally unset — the app NEEDS
        # microphone + camera access on the practice routes.
    }

    # Log to Caddy's stderr (visible via `docker-compose logs caddy`).
    log {
        output stdout
        format console
    }
}

# No www redirect — the deployment uses a subdomain
# (`confidence-detector.logicsbay.com`), so there's no
# `www.confidence-detector.logicsbay.com` variant to redirect from.
