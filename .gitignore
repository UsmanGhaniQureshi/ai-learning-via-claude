# Added by code-review-graph
.code-review-graph/

# Local tooling state — never deploy. .claude/ holds chat memory and
# settings, .cursor/ holds IDE config, .kiro/ holds AI-agent steering.
# None are needed by the running app and they leak personal data /
# clutter into deployment pulls.
.claude/
.cursor/
.kiro/

# Vite local dev cache — regenerated on every `npm run dev` /
# `vite build`. Has nothing to do with the production deploy
# (the frontend Dockerfile builds inside its own container, with
# its own Vite cache). Anywhere in the tree.
.vite/
